# Database
DATABASE_URL=postgresql+asyncpg://tradingfloor:tradingfloor_dev@localhost:5432/tradingfloor
QUESTDB_HOST=localhost
QUESTDB_ILP_PORT=9009
QUESTDB_HTTP_PORT=9000

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Exchange APIs (never commit real keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
BINANCE_API_KEY=
BINANCE_SECRET=
COINBASE_API_KEY=
COINBASE_SECRET=

# Market Data
POLYGON_API_KEY=
ALPHA_VANTAGE_KEY=

# News & Sentiment
NEWS_API_KEY=              # Free tier: 100 req/day — register at https://newsapi.org
                           # Leave blank to use Yahoo Finance RSS fallback (unlimited, no key)
SENTIMENT_BACKEND=vader    # "finbert" for full accuracy (requires pip install trading-floor[sentiment])
                           # "vader" for lightweight fallback (default — no GPU, no heavy deps)

# Macro Data (free registrations)
FRED_API_KEY=              # Free at https://fred.stlouisfed.org/docs/api/api_key.html
                           # Used for: DXY, real yields (DFII10), VIX (VIXCLS), breakevens

# Commodities — Energy
EIA_API_KEY=               # Free at https://www.eia.gov/opendata/register.php
                           # Used for: weekly petroleum status (crude stocks, gasoline, refinery utilization)
                           # API docs: https://www.eia.gov/opendata/documentation.php

# App Config
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ALLOWED_ORIGINS=http://localhost:3000

# Operating Mode
TRADING_MODE=paper
AUTONOMY_MODE=COMMANDER
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05

# Copy Trading
BINANCE_LEADERBOARD_ENABLED=true    # Set false to disable Binance top trader scraping
XRPL_WHALE_TRACKING=true            # Set false to disable XRPL whale wallet monitoring
COPY_TRADE_MIN_CONFIDENCE=0.65      # Only emit copy signals when conviction > 65%
                                    # Range: 0.5 (more signals) to 0.85 (fewer, higher quality)
