# Database
DATABASE_URL=postgresql+asyncpg://tradingfloor:tradingfloor_dev@localhost:5432/tradingfloor
QUESTDB_HOST=localhost
QUESTDB_ILP_PORT=9009
QUESTDB_HTTP_PORT=9000

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Exchange APIs (never commit real keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
BINANCE_API_KEY=
BINANCE_SECRET=
COINBASE_API_KEY=
COINBASE_SECRET=

# Market Data
POLYGON_API_KEY=
ALPHA_VANTAGE_KEY=
FRED_API_KEY=your_key_from_fred.stlouisfed.org

# Commodities (EIA for energy/oil data)
EIA_API_KEY=your_key_from_api.eia.gov

# XRPL (no key needed — public endpoints)
XRPL_WHALE_TRACKING=true

# Copy Trading
BINANCE_LEADERBOARD_ENABLED=true
COPY_TRADE_MIN_CONFIDENCE=0.65

# Position & Risk Monitoring
POSITION_MONITOR_INTERVAL_SECONDS=5
RISK_MONITOR_INTERVAL_SECONDS=30
TRAILING_STOP_TRIGGER_PCT=0.05

# App Config
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ALLOWED_ORIGINS=http://localhost:3000

# Operating Mode
TRADING_MODE=paper
AUTONOMY_MODE=COMMANDER
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
