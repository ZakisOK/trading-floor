# Database
DATABASE_URL=postgresql+asyncpg://tradingfloor:tradingfloor_dev@localhost:5432/tradingfloor
QUESTDB_HOST=localhost
QUESTDB_ILP_PORT=9009
QUESTDB_HTTP_PORT=9000

# Redis
# IMPORTANT: generate a real password with `openssl rand -hex 32` on the droplet.
# The URL must include the password when using `--requirepass` on the server.
REDIS_PASSWORD=change_me_local_only
REDIS_URL=redis://:change_me_local_only@localhost:6379/0

# Anthropic
# Model choice: Sonnet 4.6 powers most agents (Marcus, Vera, Rex, Atlas, Nova, Bull, Bear, Scout).
# Opus 4.7 is reserved for Sage (portfolio supervisor) and Diana (risk manager) where deeper reasoning matters.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Exchange APIs (never commit real keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_TRADE=true
# Toolsets exposed to the Alpaca MCP server. Order placement / cancellation
# tools are intentionally excluded so Claude Code cannot execute trades directly.
ALPACA_TOOLSETS=account,positions,stock_data,crypto_data,options_data,watchlists,assets,news
BINANCE_API_KEY=
BINANCE_SECRET=
COINBASE_API_KEY=
COINBASE_SECRET=

# Memory / Learning Stack
# Graphiti is the Zep/Graphiti temporal knowledge graph service running inside docker compose.
GRAPHITI_URL=http://graphiti:8000
ZEP_API_SECRET=change_me_local_only
# Used by Graphiti for embeddings. Leave blank to use Anthropic once we add that support.
OPENAI_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006

# Neo4j (Graphiti backend)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_local_only

# DigitalOcean (for MCP-driven droplet management)
# Personal access token from https://cloud.digitalocean.com/account/api/tokens
# Used by the DigitalOcean MCP server (.mcp.json) to manage the tradingfloor.world droplet,
# its managed databases, DNS, and deployment. Grant only the scopes you actually need.
DIGITALOCEAN_API_TOKEN=

# Market Data
POLYGON_API_KEY=
ALPHA_VANTAGE_KEY=

# Macro Data (free registrations)
FRED_API_KEY=              # Free at https://fred.stlouisfed.org/docs/api/api_key.html
                           # Used for: DGS10, DGS2, T10Y2Y (yield curve), VIXCLS,
                           #           DCOILWTICO (WTI crude), CPIAUCSL, UNRATE, DEXUSEU
                           # Powers: FREDFeed (cascade detection) + MacroAnalystAgent

# Commodities — Energy
EIA_API_KEY=               # Free at https://www.eia.gov/opendata/register.php
                           # Used for: weekly petroleum status (crude stocks, gasoline, refinery utilization)
                           # API docs: https://www.eia.gov/opendata/documentation.php

# Options Flow
UNUSUAL_WHALES_API_KEY=    # Optional — free tier uses RSS feed (no key needed)
                           # Paid key unlocks full API: https://unusualwhales.com
                           # When empty: falls back to CME public data + yfinance
                           # Powers: OptionsFlowFeed + OptionsFlowAgent

# App Config
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ALLOWED_ORIGINS=http://localhost:3000

# Operating Mode
TRADING_MODE=paper
AUTONOMY_MODE=COMMANDER
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05

# Copy Trading
BINANCE_LEADERBOARD_ENABLED=true    # Set false to disable Binance top trader scraping
XRPL_WHALE_TRACKING=true            # Set false to disable XRPL whale wallet monitoring
COPY_TRADE_MIN_CONFIDENCE=0.65      # Only emit copy signals when conviction > 65%
                                    # Range: 0.5 (more signals) to 0.85 (fewer, higher quality)
